```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
.venv/
venv/
env/

# Dependencies
node_modules/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build outputs
dist/
build/
target/
*.egg-info/

# Testing
.pytest_cache/
.mypy_cache/
```